rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (optional)
    //   - role: string (required, 'admin' or 'customer')
    //
    // Collection: orders
    // Fields:
    //   - customerName: string (required)
    //   - customerNumber: string (required)
    //   - totalEggs: number (required)
    //   - address: string (required)
    //   - totalPrice: number (required)
    //   - dueAmount: number (required)
    //   - orderDate: timestamp (required)
    //   - hatchDate: timestamp (required)
    //   - status: string (required, 'pending', 'hatching', 'completed', 'cancelled')
    //   - uid: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mahimahi2009ma@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'role']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['admin', 'customer'];
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerNumber', 'totalEggs', 'totalPrice', 'orderDate', 'hatchDate', 'status', 'uid']) &&
             data.customerName is string && data.customerName.size() < 100 &&
             data.customerNumber is string && data.customerNumber.size() < 20 &&
             data.totalEggs is number && data.totalEggs >= 0 &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.dueAmount is number &&
             data.status in ['pending', 'hatching', 'completed', 'cancelled'] &&
             data.uid is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && (request.resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidOrder(request.resource.data) && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
